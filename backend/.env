# Database
DATABASE_URL="postgresql://hst_erp_user:changeme@localhost:5432/hst_erp?schema=public"

# JWT Configuration
JWT_SECRET="hst-erp-super-secret-jwt-key-2026-production"
JWT_REFRESH_SECRET="hst-erp-super-secret-refresh-key-2026-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server Configuration
PORT=3001
NODE_ENV="development"

# CORS Configuration
CORS_ORIGIN="http://localhost:5173"

# File Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100